generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                @id @default(uuid())
  email                    String?               @unique
  emailVerified            Boolean               @default(false) @map("email_verified")
  emailVerificationToken   String?               @map("email_verification_token")
  emailVerificationExpires DateTime?             @map("email_verification_expires")
  phone                    String?               @unique
  phoneVerified            Boolean               @default(false) @map("phone_verified")
  phoneVerificationCode    String?               @map("phone_verification_code")
  phoneVerificationExpires DateTime?             @map("phone_verification_expires")
  passwordHash             String?               @map("password_hash")
  role                     UserRole
  isActive                 Boolean               @default(true) @map("is_active")
  isVip                    Boolean               @default(false) @map("is_vip")
  vipLevel                 VipLevel?             @map("vip_level")
  lastLogin                DateTime?             @map("last_login")
  failedLoginAttempts      Int                   @default(0) @map("failed_login_attempts")
  accountLocked            Boolean               @default(false) @map("account_locked")
  accountLockedUntil       DateTime?             @map("account_locked_until")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @default(now()) @map("updated_at")
  deletedAt                DateTime?             @map("deleted_at")
  ipAddress                String?               @map("ip_address")
  lastIpAddress            String?               @map("last_ip_address")
  userAgent                String?               @map("user_agent")
  preferredLanguage        String                @default("es") @map("preferred_language")
  marketingOptIn           Boolean               @default(false) @map("marketing_opt_in")
  termsAcceptedAt          DateTime?             @map("terms_accepted_at")
  privacyAcceptedAt        DateTime?             @map("privacy_accepted_at")
  profileImageUrl          String?               @map("profile_image_url")
  agency                   Agency?
  client                   Client?
  emailSettings            EmailSetting?
  externalAuth             ExternalAuth[]
  invoices                 Invoice[]
  receivedMessages         Message[]             @relation("ReceivedMessages")
  sentMessages             Message[]             @relation("SentMessages")
  notifications            Notification[]
  paymentMethods           PaymentMethodSaved[]
  payments                 Payment[]
  pointBalanceHistory      PointBalanceHistory[]
  pointTransactions        PointTransaction[]
  profile                  Profile?
  raffleEntries            RaffleEntry[]
  supportTickets           SupportTicket[]
  sentTicketMessages       TicketMessage[]       @relation("TicketMessageSender")
  originalCoupons          UserCoupon[]          @relation("OriginalCoupons")
  transferredCoupons       UserCoupon[]          @relation("TransferredCoupons")
  userCoupons              UserCoupon[]
  devices                  UserDevice[]
  userPremiumServices      UserPremiumService[]
  reported                 UserReport[]          @relation("ReportedUser")
  reportedBy               UserReport[]          @relation("ReporterUser")
  userRoles                UserRoleMapping[]
  sessions                 UserSession[]
  userVipMemberships       UserVipMembership[]

  @@map("users")
}

model ExternalAuth {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  provider       AuthMethod
  providerUserId String     @map("provider_user_id")
  providerEmail  String?    @map("provider_email")
  accessToken    String?    @map("access_token")
  refreshToken   String?    @map("refresh_token")
  tokenExpiresAt DateTime?  @map("token_expires_at")
  profileData    Json?      @map("profile_data")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @default(now()) @map("updated_at")
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("external_auth")
}

model UserSession {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  token        String      @unique
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  deviceType   DeviceType? @map("device_type")
  deviceInfo   Json?       @map("device_info")
  location     Json?
  createdAt    DateTime    @default(now()) @map("created_at")
  expiresAt    DateTime    @map("expires_at")
  lastActivity DateTime    @default(now()) @map("last_activity")
  isActive     Boolean     @default(true) @map("is_active")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Client {
  id               String           @id
  username         String?          @unique
  totalPoints      Int              @default(0) @map("total_points")
  vipUntil         DateTime?        @map("vip_until")
  preferences      Json?
  favoriteProfiles Json?            @map("favorite_profiles")
  blockedProfiles  Json?            @map("blocked_profiles")
  lastActivity     DateTime?        @map("last_activity")
  referralCode     String?          @unique @map("referral_code")
  referredBy       String?          @map("referred_by")
  totalContacts    Int              @default(0) @map("total_contacts")
  verifiedAccount  Boolean          @default(false) @map("verified_account")
  user             User             @relation(fields: [id], references: [id], onDelete: Cascade)
  referrer         Client?          @relation("ClientReferrals", fields: [referredBy], references: [id])
  referrals        Client[]         @relation("ClientReferrals")
  conversations    Conversation[]
  profileContacts  ProfileContact[]

  @@map("clients")
}

model Agency {
  id                   String                @id
  name                 String
  slug                 String                @unique
  description          String?
  shortDescription     String?               @map("short_description")
  website              String?
  address              String?
  city                 String?
  stateProvince        String?               @map("state_province")
  country              String?
  postalCode           String?               @map("postal_code")
  verificationStatus   VerificationStatus    @default(no_verificado) @map("verification_status")
  verifiedAt           DateTime?             @map("verified_at")
  verifiedBy           String?               @map("verified_by")
  logoUrl              String?               @map("logo_url")
  coverImageUrl        String?               @map("cover_image_url")
  galleryImages        Json?                 @map("gallery_images")
  socialMedia          Json?                 @map("social_media")
  businessHours        Json?                 @map("business_hours")
  commissionRate       Decimal?              @map("commission_rate")
  commissionStructure  Json?                 @map("commission_structure")
  subscriptionTier     String?               @map("subscription_tier")
  subscriptionExpires  DateTime?             @map("subscription_expires")
  paymentMethods       Json?                 @map("payment_methods")
  contactPhone         String?               @map("contact_phone")
  contactEmail         String?               @map("contact_email")
  contactWhatsapp      String?               @map("contact_whatsapp")
  totalProfiles        Int                   @default(0) @map("total_profiles")
  activeProfiles       Int                   @default(0) @map("active_profiles")
  verifiedProfiles     Int                   @default(0) @map("verified_profiles")
  rating               Decimal?
  totalRatings         Int                   @default(0) @map("total_ratings")
  featuredUntil        DateTime?             @map("featured_until")
  taxId                String?               @map("tax_id")
  legalName            String?               @map("legal_name")
  legalRepresentative  String?               @map("legal_representative")
  establishmentYear    Int?                  @map("establishment_year")
  isExclusive          Boolean               @default(false) @map("is_exclusive")
  notes                String?
  user                 User                  @relation(fields: [id], references: [id], onDelete: Cascade)
  agencyCommissions    AgencyCommission[]
  agencySubscriptions  AgencySubscription[]
  commissionPayments   CommissionPayment[]
  profileVerifications ProfileVerification[]
  profiles             Profile[]

  @@map("agencies")
}

model Profile {
  id                       String                @id
  displayName              String                @map("display_name")
  slug                     String                @unique
  realName                 String?               @map("real_name")
  gender                   GenderType
  birthDate                DateTime?             @map("birth_date") @db.Date
  age                      Int?
  agencyId                 String?               @map("agency_id")
  description              String?
  shortDescription         String?               @map("short_description")
  verificationStatus       VerificationStatus    @default(no_verificado) @map("verification_status")
  verifiedAt               DateTime?             @map("verified_at")
  verifiedBy               String?               @map("verified_by")
  verificationExpires      DateTime?             @map("verification_expires")
  height                   Int?
  weight                   Int?
  measurements             String?
  eyeColor                 String?               @map("eye_color")
  hairColor                String?               @map("hair_color")
  skinTone                 String?               @map("skin_tone")
  nationality              String?
  languages                Json?
  location                 Json?
  travelAvailability       Boolean               @default(false) @map("travel_availability")
  travelDestinations       Json?                 @map("travel_destinations")
  services                 Json?
  priceHour                Decimal?              @map("price_hour")
  priceAdditionalHour      Decimal?              @map("price_additional_hour")
  priceOvernight           Decimal?              @map("price_overnight")
  priceWeekend             Decimal?              @map("price_weekend")
  priceTravel              Decimal?              @map("price_travel")
  discountPackages         Json?                 @map("discount_packages")
  currency                 String                @default("USD")
  paymentMethods           Json?                 @map("payment_methods")
  availabilityStatus       AvailabilityStatus    @default(disponible) @map("availability_status")
  availabilitySchedule     Json?                 @map("availability_schedule")
  contactMethods           Json?                 @map("contact_methods")
  preferredContactHours    Json?                 @map("preferred_contact_hours")
  isIndependent            Boolean               @default(false) @map("is_independent")
  totalViews               Int                   @default(0) @map("total_views")
  totalContacts            Int                   @default(0) @map("total_contacts")
  totalFavorites           Int                   @default(0) @map("total_favorites")
  isFeatured               Boolean               @default(false) @map("is_featured")
  featuredUntil            DateTime?             @map("featured_until")
  boostUntil               DateTime?             @map("boost_until")
  searchBoostFactor        Int                   @default(1) @map("search_boost_factor")
  lastActivity             DateTime?             @map("last_activity")
  hasHealthCertificate     Boolean               @default(false) @map("has_health_certificate")
  healthCertificateExpires DateTime?             @map("health_certificate_expires")
  orientation              String?
  personalityTags          Json?                 @map("personality_tags")
  interests                Json?
  tattoos                  Boolean               @default(false)
  piercings                Boolean               @default(false)
  smoker                   Boolean               @default(false)
  educationLevel           String?               @map("education_level")
  aboutMe                  String?               @map("about_me")
  hidden                   Boolean               @default(false)
  agencyChanges            AgencyChange[]
  conversations            Conversation[]
  profileContacts          ProfileContact[]
  images                   ProfileImage[]
  profileMetrics           ProfileMetric[]
  profileTags              ProfileTag[]
  profileVerifications     ProfileVerification[]
  profileViews             ProfileView[]
  agency                   Agency?               @relation(fields: [agencyId], references: [id])
  user                     User                  @relation(fields: [id], references: [id], onDelete: Cascade)
  userPremiumServices      UserPremiumService[]

  @@map("profiles")
}

model ProfileImage {
  id            String    @id @default(uuid())
  profileId     String    @map("profile_id")
  imageUrl      String    @map("image_url")
  thumbnailUrl  String?   @map("thumbnail_url")
  mediumUrl     String?   @map("medium_url")
  isMain        Boolean   @default(false) @map("is_main")
  isApproved    Boolean   @default(false) @map("is_approved")
  approvedBy    String?   @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  isPublic      Boolean   @default(true) @map("is_public")
  isPrivate     Boolean   @default(false) @map("is_private")
  uploadDate    DateTime  @default(now()) @map("upload_date")
  description   String?
  orderPosition Int       @default(0) @map("order_position")
  blurHash      String?   @map("blur_hash")
  contentType   String    @default("image/jpeg") @map("content_type")
  fileSize      Int?      @map("file_size")
  dimensions    Json?
  tags          Json?
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_images")
}

model PointTransaction {
  id                  String                @id @default(uuid())
  userId              String                @map("user_id")
  action              PointAction
  points              Int
  referenceId         String?               @map("reference_id")
  referenceType       String?               @map("reference_type")
  description         String?
  createdAt           DateTime              @default(now()) @map("created_at")
  createdBy           String?               @map("created_by")
  expirationDate      DateTime?             @map("expiration_date")
  isExpired           Boolean               @default(false) @map("is_expired")
  transactionBatch    String?               @map("transaction_batch")
  pointBalanceHistory PointBalanceHistory[]
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  raffleEntry         RaffleEntry[]
  userVipMembership   UserVipMembership[]

  @@map("point_transactions")
}

model PointBalanceHistory {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  previousBalance Int               @map("previous_balance")
  newBalance      Int               @map("new_balance")
  transactionId   String?           @map("transaction_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  transaction     PointTransaction? @relation(fields: [transactionId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_balance_history")
}

model CouponPackage {
  id                  String              @id @default(uuid())
  name                String
  description         String?
  shortDescription    String?             @map("short_description")
  price               Decimal
  discountPrice       Decimal?            @map("discount_price")
  currency            String              @default("USD")
  pointsGranted       Int                 @map("points_granted")
  sorteoEntries       Int                 @default(0) @map("sorteo_entries")
  isActive            Boolean             @default(true) @map("is_active")
  isFeatured          Boolean             @default(false) @map("is_featured")
  minPurchaseLevel    Int                 @default(0) @map("min_purchase_level")
  maxPurchasesPerUser Int?                @map("max_purchases_per_user")
  totalAvailable      Int?                @map("total_available")
  imageUrl            String?             @map("image_url")
  startDate           DateTime?           @map("start_date")
  endDate             DateTime?           @map("end_date")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @map("updated_at")
  createdBy           String?             @map("created_by")
  packageItems        CouponPackageItem[]

  @@map("coupon_packages")
}

model CouponPackageItem {
  id                 String        @id @default(uuid())
  packageId          String        @map("package_id")
  discountPercentage Int           @map("discount_percentage")
  quantity           Int           @default(1)
  validDays          Int           @default(30) @map("valid_days")
  minPurchaseAmount  Decimal?      @map("min_purchase_amount")
  maxDiscountAmount  Decimal?      @map("max_discount_amount")
  applicableServices Json?         @map("applicable_services")
  package            CouponPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  userCoupons        UserCoupon[]

  @@map("coupon_package_items")
}

model UserCoupon {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  packageItemId      String?            @map("package_item_id")
  code               String             @unique
  discountPercentage Int                @map("discount_percentage")
  isUsed             Boolean            @default(false) @map("is_used")
  createdAt          DateTime           @default(now()) @map("created_at")
  expiresAt          DateTime           @map("expires_at")
  usedAt             DateTime?          @map("used_at")
  usedFor            String?            @map("used_for")
  usedInPayment      String?            @map("used_in_payment")
  isTransferable     Boolean            @default(false) @map("is_transferable")
  transferredTo      String?            @map("transferred_to")
  transferredAt      DateTime?          @map("transferred_at")
  originalOwner      String?            @map("original_owner")
  paymentUsed        Payment?           @relation("CouponPayment")
  originalOwnerUser  User?              @relation("OriginalCoupons", fields: [originalOwner], references: [id])
  packageItem        CouponPackageItem? @relation(fields: [packageItemId], references: [id])
  transferredToUser  User?              @relation("TransferredCoupons", fields: [transferredTo], references: [id])
  payment            Payment?           @relation(fields: [usedInPayment], references: [id])
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_coupons")
}

model Conversation {
  id                 String    @id @default(uuid())
  clientId           String    @map("client_id")
  profileId          String    @map("profile_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @map("updated_at")
  isActive           Boolean   @default(true) @map("is_active")
  isArchived         Boolean   @default(false) @map("is_archived")
  isBlocked          Boolean   @default(false) @map("is_blocked")
  blockedBy          String?   @map("blocked_by")
  lastMessageAt      DateTime? @map("last_message_at")
  totalMessages      Int       @default(0) @map("total_messages")
  unreadClient       Int       @default(0) @map("unread_client")
  unreadProfile      Int       @default(0) @map("unread_profile")
  lastMessagePreview String?   @map("last_message_preview")
  metadata           Json?
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  profile            Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@unique([clientId, profileId])
  @@map("conversations")
}

model Message {
  id                 String        @id @default(uuid())
  conversationId     String        @map("conversation_id")
  senderId           String        @map("sender_id")
  recipientId        String        @map("recipient_id")
  content            String
  contentType        String        @default("text") @map("content_type")
  attachments        Json?
  status             MessageStatus @default(enviado)
  createdAt          DateTime      @default(now()) @map("created_at")
  deliveredAt        DateTime?     @map("delivered_at")
  readAt             DateTime?     @map("read_at")
  deletedBySender    Boolean       @default(false) @map("deleted_by_sender")
  deletedByRecipient Boolean       @default(false) @map("deleted_by_recipient")
  reaction           String?
  edited             Boolean       @default(false)
  editedAt           DateTime?     @map("edited_at")
  originalContent    String?       @map("original_content")
  metadata           Json?
  conversation       Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  recipient          User          @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  sender             User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model ProfileContact {
  id                  String        @id @default(uuid())
  clientId            String        @map("client_id")
  profileId           String        @map("profile_id")
  contactMethod       ContactMethod
  contactData         String?       @map("contact_data")
  createdAt           DateTime      @default(now()) @map("created_at")
  pointsAwarded       Boolean       @default(false) @map("points_awarded")
  pointsTransactionId String?       @map("points_transaction_id")
  initiatedBy         String?       @map("initiated_by")
  isSuccessful        Boolean?      @map("is_successful")
  notes               String?
  location            Json?
  deviceInfo          Json?         @map("device_info")
  client              Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  profile             Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_contacts")
}

model ProfileView {
  id          String      @id @default(uuid())
  profileId   String      @map("profile_id")
  viewerId    String?     @map("viewer_id")
  viewedAt    DateTime    @default(now()) @map("viewed_at")
  ipAddress   String?     @map("ip_address")
  sessionId   String?     @map("session_id")
  deviceType  DeviceType?
  deviceInfo  Json?       @map("device_info")
  referrer    String?
  duration    Int?
  location    Json?
  searchQuery String?     @map("search_query")
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_views")
}

model PaymentMethodSaved {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  paymentMethod   PaymentMethod @map("payment_method")
  isDefault       Boolean       @default(false) @map("is_default")
  provider        String
  providerToken   String?       @map("provider_token")
  cardLastFour    String?       @map("card_last_four")
  cardBrand       String?       @map("card_brand")
  cardExpiryMonth Int?          @map("card_expiry_month")
  cardExpiryYear  Int?          @map("card_expiry_year")
  billingName     String?       @map("billing_name")
  billingAddress  Json?         @map("billing_address")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @map("updated_at")
  isVerified      Boolean       @default(false) @map("is_verified")
  isActive        Boolean       @default(true) @map("is_active")
  metadata        Json?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@map("payment_methods_saved")
}

model Payment {
  id                    String                 @id @default(uuid())
  userId                String                 @map("user_id")
  amount                Decimal
  currency              String                 @default("USD")
  paymentType           PaymentType            @map("payment_type")
  referenceId           String?                @map("reference_id")
  referenceType         String?                @map("reference_type")
  paymentMethodType     PaymentMethod          @map("payment_method")
  paymentMethodId       String?                @map("payment_method_id")
  provider              String
  providerTransactionId String?                @map("provider_transaction_id")
  providerFee           Decimal?               @map("provider_fee")
  platformFee           Decimal?               @map("platform_fee")
  totalFees             Decimal?               @map("total_fees")
  netAmount             Decimal?               @map("net_amount")
  status                PaymentStatus          @default(pendiente)
  statusDetail          String?                @map("status_detail")
  statusUpdatedAt       DateTime?              @map("status_updated_at")
  couponId              String?                @unique @map("coupon_id")
  discountAmount        Decimal                @default(0) @map("discount_amount")
  taxAmount             Decimal                @default(0) @map("tax_amount")
  taxRate               Decimal?               @map("tax_rate")
  billingAddress        Json?                  @map("billing_address")
  invoiceNumber         String?                @map("invoice_number")
  invoiceUrl            String?                @map("invoice_url")
  receiptUrl            String?                @map("receipt_url")
  refundId              String?                @map("refund_id")
  refundReason          String?                @map("refund_reason")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @default(now()) @map("updated_at")
  completedAt           DateTime?              @map("completed_at")
  canceledAt            DateTime?              @map("canceled_at")
  canceledReason        String?                @map("canceled_reason")
  metadata              Json?
  ipAddress             String?                @map("ip_address")
  deviceInfo            Json?                  @map("device_info")
  agencySubscriptions   AgencySubscription[]
  invoice               Invoice?
  statusHistory         PaymentStatusHistory[]
  coupon                UserCoupon?            @relation("CouponPayment", fields: [couponId], references: [id])
  savedPaymentMethod    PaymentMethodSaved?    @relation(fields: [paymentMethodId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileVerifications  ProfileVerification[]
  refunds               Refund[]
  userCoupons           UserCoupon[]
  userPremiumServices   UserPremiumService[]
  userVipMemberships    UserVipMembership[]

  @@map("payments")
}

model PaymentStatusHistory {
  id             String         @id @default(uuid())
  paymentId      String         @map("payment_id")
  previousStatus PaymentStatus? @map("previous_status")
  newStatus      PaymentStatus  @map("new_status")
  changedAt      DateTime       @default(now()) @map("changed_at")
  changedBy      String?        @map("changed_by")
  reason         String?
  metadata       Json?
  payment        Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_status_history")
}

model Invoice {
  id             String    @id @default(uuid())
  paymentId      String?   @unique @map("payment_id")
  userId         String    @map("user_id")
  invoiceNumber  String    @unique @map("invoice_number")
  invoiceDate    DateTime  @default(now()) @map("invoice_date")
  dueDate        DateTime? @map("due_date")
  totalAmount    Decimal   @map("total_amount")
  currency       String    @default("USD")
  status         String    @default("emitida")
  paidAt         DateTime? @map("paid_at")
  pdfUrl         String?   @map("pdf_url")
  items          Json?
  billingDetails Json?     @map("billing_details")
  taxDetails     Json?     @map("tax_details")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  payment        Payment?  @relation(fields: [paymentId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Refund {
  id               String    @id @default(uuid())
  paymentId        String    @map("payment_id")
  amount           Decimal
  reason           String
  requestedBy      String    @map("requested_by")
  approvedBy       String?   @map("approved_by")
