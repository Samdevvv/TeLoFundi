  currency                 String               @default("USD")
  billingInterval          String               @default("monthly") @map("billing_interval")
  maxProfiles              Int?                 @map("max_profiles")
  featuredProfilesIncluded Int                  @default(0) @map("featured_profiles_included")
  verificationCredits      Int                  @default(0) @map("verification_credits")
  commissionDiscount       Decimal              @default(0) @map("commission_discount")
  additionalBenefits       Json?                @map("additional_benefits")
  isActive                 Boolean              @default(true) @map("is_active")
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @default(now()) @map("updated_at")
  agencySubscriptions      AgencySubscription[]

  @@map("agency_subscription_plans")
}

model AgencySubscription {
  id                 String                 @id @default(uuid())
  agencyId           String                 @map("agency_id")
  planId             String                 @map("plan_id")
  startsAt           DateTime               @default(now()) @map("starts_at")
  expiresAt          DateTime               @map("expires_at")
  isActive           Boolean                @default(true) @map("is_active")
  autoRenew          Boolean                @default(true) @map("auto_renew")
  paymentId          String?                @map("payment_id")
  canceledAt         DateTime?              @map("canceled_at")
  cancellationReason String?                @map("cancellation_reason")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @default(now()) @map("updated_at")
  agency             Agency                 @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  payment            Payment?               @relation(fields: [paymentId], references: [id])
  plan               AgencySubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("agency_subscriptions")
}

model AgencyCommission {
  id                   String    @id @default(uuid())
  agencyId             String    @map("agency_id")
  profileId            String?   @map("profile_id")
  commissionPercentage Decimal   @map("commission_percentage")
  startsAt             DateTime  @default(now()) @map("starts_at")
  endsAt               DateTime? @map("ends_at")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  notes                String?
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_commissions")
}

model CommissionPayment {
  id            String    @id @default(uuid())
  agencyId      String    @map("agency_id")
  profileId     String?   @map("profile_id")
  amount        Decimal
  currency      String    @default("USD")
  paymentDate   DateTime  @default(now()) @map("payment_date")
  paymentMethod String?
  transactionId String?   @map("transaction_id")
  description   String?
  periodStart   DateTime? @map("period_start")
  periodEnd     DateTime? @map("period_end")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String?   @map("created_by")
  agency        Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("commission_payments")
}

model Role {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  isSystem    Boolean           @default(false) @map("is_system")
  createdAt   DateTime          @default(now()) @map("created_at")
  permissions RolePermission[]
  userRoles   UserRoleMapping[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  resource        String
  action          String
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleMapping {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  previousState Json?    @map("previous_state")
  newState      Json?    @map("new_state")
  changes       Json?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model AgencyApprovalRequest {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  agencyId     String    @map("agency_id")
  status       String    @default("pendiente")
  requestEmail String    @map("request_email")
  requestData  Json?     @map("request_data")
  approvedBy   String?   @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  notes        String?
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("agency_approval_requests")
}

