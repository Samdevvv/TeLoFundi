# Configuración del servidor
PORT=5000
NODE_ENV=development

# Configuración de la base de datos
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=C123456
DB_NAME=TeLoFundiDev
DATABASE_URL="postgresql://postgres:C123456@localhost:5432/TeLoFundiDev?schema=public"

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura
JWT_EXPIRATION=24h

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_S3_BUCKET=tu_bucket_name

# Stripe API
STRIPE_SECRET_KEY=tu_stripe_secret_key
STRIPE_WEBHOOK_SECRET=tu_stripe_webhook_secret

# Configuración de correo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_o_app_password
EMAIL_FROM=no-reply@tudominio.com

# URL de la API (para Swagger)
API_URL=http://localhost:5000